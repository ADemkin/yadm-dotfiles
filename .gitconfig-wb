[user]
    name = "demkin.anton"
    email = "demkin.anton@rwb.ru"
    signingKey = ~/.ssh/id_ed25519.pub
[commit]
    gpgsign = true
[gpg]
    format = ssh
[core]
    sshCommand = "ssh -i ~/.ssh/id_ed25519 -F /dev/null"
[alias]
    wb = "!echo wildberries config is loaded"
[tag]
    gpgSign = true
